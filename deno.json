{
  "name": "@waystation/core",
  "version": "0.0.1",
  "exports": {
    ".": "./src/mod.ts",
    "./schema": "./schema.sql"
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-env --allow-run",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "cli": "deno run --allow-read --allow-write --allow-env --allow-run src/cli.ts",
    "install": "deno install --global --force --config deno.json -n way --allow-read --allow-write --allow-env --allow-run src/cli.ts"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.10",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.6",
    "@std/assert": "jsr:@std/assert@^1.0.10",
    "@std/encoding": "jsr:@std/encoding@^1.0.5",
    "marked": "npm:marked@^14.1.4",
    "marked-terminal": "npm:marked-terminal@^7.3.0"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": [
        "no-explicit-any",
        "require-await"
      ]
    }
  },
  "publish": {
    "include": ["src/", "schema.sql", "README.md", "LICENSE", "deno.json"],
    "exclude": ["tests/", "**/*.test.ts"]
  }
}
